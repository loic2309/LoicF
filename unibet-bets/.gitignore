# Secrets
.env

# Cache policy: everything in odds_cache/ is now persistent on the repo.
#   - advanced_<event_id>.json — fetched once per event, kept forever.
#   - odds_YYYY-MM-DD.json     — daily bulk h2h+totals fetched once each
#                                morning by the cron. Manual refreshes
#                                reuse the cached file → 0 credits.
#   - buteur_*                 — legacy, deprecated.
data/odds_cache/buteur_*.json
data/buteur_*.json

# Volatile reference data (fetched live)
data/events.json
data/elo_raw.tsv

# User-specific runtime state
data/picks_history.json
data/results_history.json
data/manual_outcomes.json

# Generated output
bets.html

# Python
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
.pytest_cache/
.venv/
venv/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
